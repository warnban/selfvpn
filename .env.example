# === Telegram ===
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
ADMIN_IDS=123456789

# === Тарифы (рубли) ===
DAILY_PRICE_RUB=10
TRIAL_DAYS=2
REFERRAL_BONUS_RUB=5

# === Telegram Stars (оплата в боте) ===
STARS_PER_DAY=6
STARS_ENABLED=true

# === Брендинг ===
BRAND_NAME=Интернет от дяди Сани
SUPPORT_TG=aleblanche

# === Веб-кабинет и админка ===
# Для SEO/SMM укажи реальный домен с HTTPS (не IP):
WEB_BASE_URL=https://daddyvpn.site
WEB_SECRET_KEY=сгенерируй-длинную-случайную-строку
ADMIN_WEB_PASSWORD=сложный-пароль-админки

# === Amnezia Panel API (PRVTPRO на этом же VPS) ===
PANEL_URL=http://127.0.0.1:5000
PANEL_API_TOKEN=awp_your_token_here
PANEL_SERVER_ID=0
PANEL_PROTOCOL=awg2
# Имя сервера в Amnezia: "BRAND_NAME NL" (код страны VPN-сервера)
PANEL_SERVER_COUNTRY=NL
# Несколько серверов в панели: id панели → код страны
# PANEL_SERVER_LABELS=0:NL,1:DE,2:FI

# === Freekassa (автооплата в веб-кабинете, API) ===
FREEKASSA_MERCHANT_ID=0
FREEKASSA_API_KEY=
FREEKASSA_SECRET_2=
# Секретное слово 1 (SCI) — не нужно для API, можно оставить пустым
FREEKASSA_SECRET_1=
# IP сервера, если клиентский IP недоступен (127.0.0.1 блокируется Freekassa)
# FREEKASSA_CLIENT_IP_FALLBACK=72.56.124.163

# === Оплата (ручная модерация, если Freekassa не настроена) ===
PAYMENT_CARD=2200 0000 0000 0000
PAYMENT_BANK=Сбербанк
PAYMENT_HOLDER=Иван И.

# === SMTP (Timeweb) ===
# 465 = SSL (SMTP_USE_SSL=true), 587 = STARTTLS (SMTP_USE_SSL=false, SMTP_PORT=587)
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=your-mail-password
SMTP_FROM=noreply@yourdomain.ru
SMTP_USE_SSL=true
SMTP_TIMEOUT=30

# === База данных ===
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
UPLOADS_DIR=./data/uploads

# === Списание раз в сутки (03:00 MSK) ===
BILLING_HOUR=3
